
const OLLAMA_URL = "http://127.0.0.1:11434/api/generate";

export async function askAgent(promptUsuario) {
   
    const systemPrompt = "Eres un motor lógico local. Responde de forma precisa y concisa. Si te piden acciones del sistema operativo, responde: OPERACIÓN DENEGADA.";
    
    const promptCompleto = `${systemPrompt}\n\nUsuario: ${promptUsuario}\nAsistente:`;

    const payload = {
        model: "gemma2:2b",
        prompt: promptCompleto,
        stream: false
    };

    try {
        const respuesta = await fetch(OLLAMA_URL, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(payload)
        });

        const data = await respuesta.json();
        return data.response.trim();
    } catch (error) {
        console.error("[ERROR] Falla al conectar con Ollama:", error.message);
        return "Error interno del agente.";
    }
}
